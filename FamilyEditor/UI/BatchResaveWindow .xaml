<Window x:Class="MagicEntry.Plugins.FamilyEditor.Views.BatchResaveWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Все открытые файлы"
        Height="400"
        Width="300">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхние кнопки -->
        <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
            <Button Content="Выбрать все" Width="120" Margin="0 0 5 0" Click="SelectAll_Click"/>
            <Button Content="Снять выбор" Width="120" Click="DeselectAll_Click"/>
        </StackPanel>

        <!-- Рамка со списком -->
        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" CornerRadius="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ListBox ItemsSource="{Binding Documents}" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox Content="{Binding Name}"
                                  IsChecked="{Binding IsSelected}"
                                  Margin="5"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </ScrollViewer>
        </Border>

        <!-- Нижние кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0 10 0 0">
            <Button Content="Пересохранить" Width="130" Margin="0 0 10 0" Click="Resave_Click"/>
            <Button Content="Сохранить" Width="100" Click="Save_Click"/>
        </StackPanel>
    </Grid>
</Window>